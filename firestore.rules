rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidSaveDocument(data) {
      return hasOnlyAllowedFields([
               "saveSchemaVersion",
               "contentVersion",
               "lastProcessedAt",
               "snapshot",
               "highestStage",
               "displayName",
               "updatedAt"
             ]) &&
             data.saveSchemaVersion is number && data.saveSchemaVersion == 1 &&
             data.contentVersion is string && data.contentVersion.size() > 0 && data.contentVersion.size() < 128 &&
             data.lastProcessedAt is number && data.lastProcessedAt >= 0 &&
             data.snapshot is map &&
             data.highestStage is number && data.highestStage >= 1 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 80 &&
             data.updatedAt is number && data.updatedAt >= 0;
    }

    match /saves/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidSaveDocument(request.resource.data);
      allow update: if isOwner(userId) && isValidSaveDocument(request.resource.data);
      allow delete: if false;
    }
  }
}

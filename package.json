{
  "name": "endless-gacha-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "pnpm --filter @endless-gacha/web dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "pnpm --filter \"./packages/*\" run typecheck && pnpm --filter \"./apps/*\" run typecheck",
    "test:unit": "vitest run --config vitest.workspace.ts",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "build": "pnpm --filter \"./packages/*\" run build && pnpm --filter \"./apps/*\" run build",
    "deploy:pages": "pnpm build && npx wrangler pages deploy apps/web/dist --project-name endless-gacha-rebuild --branch main",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}

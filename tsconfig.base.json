{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@endless-gacha/shared": ["packages/shared/src/index.ts"],
      "@endless-gacha/game-core": ["packages/game-core/src/index.ts"],
      "@endless-gacha/game-data": ["packages/game-data/src/index.ts"],
      "@endless-gacha/firebase-adapter": ["packages/firebase-adapter/src/index.ts"],
      "@endless-gacha/ui": ["packages/ui/src/index.ts"]
    }
  }
}
